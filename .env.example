# .env.example — Bloom by BotaniK
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env (voir .gitignore)

# ===========================================
# API KEYS — Agents IA
# ===========================================

# Clé API OpenAI (pour agents GPT-4)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Clé API Anthropic (pour agents Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Clé API Google (pour agents Gemini)
GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ===========================================
# BASE DE DONNEES
# ===========================================

# Connexion base de données principale
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bloom_botanik
DB_USER=bloom_user
DB_PASSWORD=your_password_here

# ===========================================
# PUBMED / NCBI API
# ===========================================

# Clé NCBI pour recherches PubMed (optionnel mais recommandé)
NCBI_API_KEY=xxxxxxxxxxxxxxxxxxxx
NCBI_EMAIL=your@email.com

# ===========================================
# GITHUB
# ===========================================

# Token GitHub pour actions automatisées
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=bloombybotanik-arch/Bloom_by_BotaniK

# ===========================================
# CONFIGURATION AGENTS
# ===========================================

# Environnement (development | staging | production)
ENVIRONMENT=development

# Niveau de logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Langue par défaut des agents
AGENT_LANGUAGE=fr

# Délai maximum de traitement par agent (en secondes)
AGENT_TIMEOUT=300

# ===========================================
# NOTIFICATIONS
# ===========================================

# Webhook Slack pour notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Email de notification
NOTIFICATION_EMAIL=bloom@votredomaine.com

# ===========================================
# STOCKAGE
# ===========================================

# Chemin racine du dépôt local
REPO_ROOT_PATH=/path/to/Bloom_by_BotaniK

# Dossier de sortie des fiches générées
OUTPUT_PATH=./02_LIBRARY/plants/
