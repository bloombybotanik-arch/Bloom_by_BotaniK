# ===========================================
# .gitignore — Bloom by BotaniK
# ===========================================

# Variables d'environnement (SECURITE CRITIQUE)
.env
.env.local
.env.production
.env.staging
*.env

# Secrets et clés API
secrets/
*.key
*.pem
*.p12
*.pfx

# Système d'exploitation
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
env/
ENV/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Logs
logs/
*.log
*.log.*
log/

# Fichiers temporaires
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# IDE et éditeurs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.cursor/

# Tests
.pytest_cache/
.coverage
htmlcov/
.tox/

# Bases de données locales
*.db
*.sqlite
*.sqlite3

# Fichiers de cache
.cache/
*.cache

# Outputs locaux (ne pas committer les générations automatiques non validées)
09_TESTS/outputs/
07_LOGS/local/

# Fichiers volumineux (LFS recommandé)
*.pdf
*.xlsx
*.csv

# EXCEPTIONS (forcer le suivi de certains fichiers)
!.env.example
!.gitkeep
!.gitignore
